    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let text = '';\n\ntry {\n  const content = $input.item.json.content;\n  if (content && content[0] && content[0].text) {\n    text = content[0].text;\n  } else if ($input.item.json.text) {\n    text = $input.item.json.text;\n  } else if (typeof $input.item.json === 'string') {\n    text = $input.item.json;\n  }\n} catch(e) {\n  text = '';\n}\n\nlet verdict = 'false';\nlet fit = 'low';\nlet reason = '';\n\ntry {\n  const match = text.match(/\\{[^}]+\\}/);\n  if (match) {\n    const parsed = JSON.parse(match[0]);\n    verdict = parsed.verdict || 'false';\n    fit = parsed.fit || 'low';\n    reason = parsed.reason || '';\n  }\n} catch(e) {\n  reason = 'Parse error';\n}\n\nconst jobNode = $('Code in JavaScript').item.json;\n\nreturn {\n  json: {\n    verdict,\n    fit,\n    reason,\n    jobTitle: jobNode.jobTitle || '',\n    company: jobNode.company || '',\n    location: jobNode.location || '',\n    jobUrl: jobNode.jobUrl || '',\n    date: new Date().toISOString().split('T')[0]\n  }\n};"
      },
