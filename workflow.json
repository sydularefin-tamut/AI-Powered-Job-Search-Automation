            {
              "content": "=Is this job a good match for the candidate? Skills: Financial Analysis, GL Accounting, Reconciliation, FPA, Budgeting, AML/CFT, QuickBooks, Excel, CISA, MBA Finance, Green Card, Dallas TX.\n\nJob Title: {{ $json.jobTitle }}\nCompany: {{ $json.company }}\nDescription: {{ $json.descriptionText }}\n\nReply ONLY with this JSON, nothing else:\n{\"verdict\": \"true\", \"fit\": \"high\", \"reason\": \"one sentence\"}\nor\n{\"verdict\": \"false\", \"fit\": \"low\", \"reason\": \"one sentence\"}"
            }
          ]
        },
        "options": {}
