    {
      "parameters": {
        "jsCode": "const allJobs = [];\n\nfor (const item of $input.all()) {\n  const jobs = (item.json.data || []).slice(0, 2);\n  for (const job of jobs) {\n    allJobs.push({\n      json: {\n        jobTitle: job.job_title || '',\n        company: job.employer_name || '',\n        location: (job.job_city || '') + ', ' + (job.job_state || ''),\n        descriptionText: (job.job_description || '').substring(0, 2000),\n        jobUrl: job.job_apply_link || job.job_google_link || ''\n      }\n    });\n  }\n}\n\nif (allJobs.length === 0) {\n  return [{ json: { error: 'No jobs found today' } }];\n}\n\nreturn allJobs;"
      },
